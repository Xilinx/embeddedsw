      <memberdef kind="function" id="group__xnvm__mailbox__apis_1ga3ce66c6266190912ba2552c2bc1701c7" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>int</type>
        <definition>int XNvm_ProcessMailbox</definition>
        <argsstring>(XMailbox *MailboxPtr, u32 *MsgPtr, u32 MsgLen)</argsstring>
        <name>XNvm_ProcessMailbox</name>
        <param>
          <type>XMailbox *</type>
          <declname>MailboxPtr</declname>
        </param>
        <param>
          <type>u32 *</type>
          <declname>MsgPtr</declname>
        </param>
        <param>
          <type>u32</type>
          <declname>MsgLen</declname>
        </param>
        <briefdescription>
<para>This function sends IPI request to the target module and gets the response from it. </para>        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>MailboxPtr</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to mailbox instance </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>MsgPtr</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to the payload message </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>MsgLen</parametername>
</parameternamelist>
<parameterdescription>
<para>Length of the message</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para><itemizedlist>
<listitem><para>XST_SUCCESS If the IPI send and receive is successful</para></listitem><listitem><para>XST_FAILURE If there is a failure</para></listitem></itemizedlist>
</para></simplesect>
<simplesect kind="note"><para>Payload consists of API id and call arguments to be written in IPI buffer </para></simplesect>
</para>        </detaileddescription>
        <inbodydescription>
<para><itemizedlist>
<listitem><para>Send IPI CDO to PLM. Return XST_FAILURE, if failure in IPI send request.</para></listitem><listitem><para>Wait for IPI response from PLM with a default timeout of 2 seconds. If the timeout exceeds, then error is returned otherwise it returns the status of the IPI response.</para></listitem></itemizedlist>
</para>        </inbodydescription>
