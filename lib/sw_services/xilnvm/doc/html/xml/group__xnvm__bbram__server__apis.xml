      <memberdef kind="function" id="group__xnvm__bbram__server__apis_1ga98ba40768aa9f879dfc0640a20ffa0c4" prot="public" static="yes" const="no" explicit="no" inline="yes" virt="non-virtual">
        <type>int</type>
        <definition>static int XNvm_BbramEnablePgmMode</definition>
        <argsstring>(void)</argsstring>
        <name>XNvm_BbramEnablePgmMode</name>
        <param>
          <type>void</type>
        </param>
        <briefdescription>
<para>This function enables the BBRAM programming mode by writing to the BBRAM_PGM_MODE register with the required value. </para>        </briefdescription>
        <detaileddescription>
<para><simplesect kind="return"><para><itemizedlist>
<listitem><para>XST_SUCCESS Enabled programming mode.</para></listitem><listitem><para>XNVM_BBRAM_ERROR_PGM_MODE_ENABLE_TIMEOUT On failure. </para></listitem></itemizedlist>
</para></simplesect>
</para>        </detaileddescription>
        <inbodydescription>
<para><itemizedlist>
<listitem><para>Write PassCode 0x757BDF0DU to BBRAM_PGM_MODE register to enable programming mode. Wait for BBRAM_PGM_MODE_DONE bit to set in BBRAM_STATUS register with timeout of 1 second. If timed out return timeout error else Return XST_SUCCESS.</para></listitem></itemizedlist>
</para>        </inbodydescription>
        <location file="/proj/xhdsswstaff1/bhawanas/patch_integration/auto_jobs/esw_github_doxy/git/2026.1/embeddedsw/lib/sw_services/xilnvm/src/versal_gen/common/server/xnvm_bbram.c" line="118" column="1" bodyfile="/proj/xhdsswstaff1/bhawanas/patch_integration/auto_jobs/esw_github_doxy/git/2026.1/embeddedsw/lib/sw_services/xilnvm/src/versal_gen/common/server/xnvm_bbram.c" bodystart="396" bodyend="417"/>
      </memberdef>
