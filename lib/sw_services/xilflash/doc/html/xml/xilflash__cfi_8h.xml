      <memberdef kind="define" id="xilflash__cfi_8h_1a12bd0c89aecceb6ce7e6449d0a76137a" prot="public" static="no">
        <name>XFL_CFI_POSITION_PTR</name>
        <param><defname>Ptr</defname></param>
        <param><defname>BaseAddr</defname></param>
        <param><defname>Interleave</defname></param>
        <param><defname>ByteAddr</defname></param>
        <initializer>(								  	\
			Ptr = (void*)((u32)BaseAddr + ((u32)Interleave *	  	\
					(u32)ByteAddr))	  	\
	)</initializer>
        <briefdescription>
<para>Moves the CFI data pointer to a physical address that corresponds to a specific CFI byte offset. </para>        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>Ptr</parametername>
</parameternamelist>
<parameterdescription>
<para>is the pointer to modify. Can be of any type. </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>BaseAddr</parametername>
</parameternamelist>
<parameterdescription>
<para>is the base address of flash part. </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>Interleave</parametername>
</parameternamelist>
<parameterdescription>
<para>is the byte interleaving (based on part layout). </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>ByteAddr</parametername>
</parameternamelist>
<parameterdescription>
<para>is the byte offset within CFI data to read.</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>The Ptr argument is set to point at the CFI byte specified by the ByteAddr parameter. </para></simplesect>
</para>        </detaileddescription>
