        <briefdescription>
<para>This function validates the KDF input parameters. </para>        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>KdfParamsPtr</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to <ref refid="struct_x_asu___kdf_params" kindref="compound">XAsu_KdfParams</ref> structure which holds the parameters of KDF input arguments.</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para><itemizedlist>
<listitem><para>XST_SUCCESS, if KDF input parameters validation is successful.</para></listitem><listitem><para>XST_FAILURE, if KDF input parameters validation fails. </para></listitem></itemizedlist>
</para></simplesect>
</para>        </detaileddescription>
        <inbodydescription>
