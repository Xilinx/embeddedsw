        <briefdescription>
<para>This function validates the input parameters for ECIES. </para>        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>EciesParams</parametername>
</parameternamelist>
<parameterdescription>
