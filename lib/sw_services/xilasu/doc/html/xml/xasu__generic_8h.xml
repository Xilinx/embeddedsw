        <definition>s32 XAsu_IsBufferNonZero</definition>
        <argsstring>(u8 *Buffer, u32 Length)</argsstring>
        <name>XAsu_IsBufferNonZero</name>
        <param>
          <type>u8 *</type>
          <declname>Buffer</declname>
        </param>
        <param>
          <type>u32</type>
          <declname>Length</declname>
