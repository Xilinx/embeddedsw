        <definition>u32 XSem_Notifier::Module</definition>
        <argsstring></argsstring>
        <name>Module</name>
        <briefdescription>
<para>The module information to receive notifications. </para>        </briefdescription>
        <detaileddescription>
<para>Module can be either CRAM or NPI.<itemizedlist>
<listitem><para>For CRAM: use XSEM_NOTIFY_CRAM</para></listitem><listitem><para>For NPI: use XSEM_NOTIFY_NPI </para></listitem></itemizedlist>
</para>        </detaileddescription>
