        <briefdescription>
<para>This function stores digest table for given data Id. </para>        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>MetaHdrPtr</parametername>
</parameternamelist>
