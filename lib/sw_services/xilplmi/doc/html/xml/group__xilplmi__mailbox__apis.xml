        <definition>int XPlmi_ProcessMailbox</definition>
        <argsstring>(XPlmi_ClientInstance *ClientPtr, u32 *MsgPtr, u32 MsgLen)</argsstring>
        <name>XPlmi_ProcessMailbox</name>
        <param>
          <type><ref refid="struct_x_plmi___client_instance" kindref="compound">XPlmi_ClientInstance</ref> *</type>
