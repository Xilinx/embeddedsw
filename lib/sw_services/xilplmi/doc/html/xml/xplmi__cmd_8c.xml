      <sectiondef kind="func">
      <memberdef kind="function" id="group__xilplmi__server__apis_1ga2a3723fdc064e5a4d8086bea79bd3a28" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>int</type>
        <definition>int XPlmi_CmdExecute</definition>
        <argsstring>(XPlmi_Cmd *CmdPtr)</argsstring>
        <name>XPlmi_CmdExecute</name>
        <param>
          <type>XPlmi_Cmd *</type>
          <declname>CmdPtr</declname>
        </param>
        <briefdescription>
<para>This function will call the command handler registered with the command. </para>        </briefdescription>
        <detaileddescription>
<para>Command handler shall execute the command till the payload length.</para><para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>CmdPtr</parametername>
</parameternamelist>
<parameterdescription>
<para>is pointer to command structure</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para><itemizedlist>
<listitem><para>XST_SUCCESS on success.</para></listitem><listitem><para>XPLMI_ERR_MODULE_NOT_REGISTERED if the module is not registered.</para></listitem><listitem><para>XPLMI_ERR_CMD_APIID on invalid module and unregistered CMD ID.</para></listitem><listitem><para>XPLMI_ERR_CMD_HANDLER_NULL if command handler is not registered.</para></listitem><listitem><para>XPLMI_ERR_CDO_CMD on invalid CDO command handler. </para></listitem></itemizedlist>
</para></simplesect>
</para>        </detaileddescription>
        <inbodydescription>
<para><itemizedlist>
<listitem><para>Validate Module registration.</para></listitem><listitem><para>Validate if API is registered.</para></listitem><listitem><para>Validate the module handler.</para></listitem><listitem><para>Execute the API.</para></listitem><listitem><para>Increment the processed length and it can be used during resume</para></listitem><listitem><para>Assign the same handler for Resume </para></listitem></itemizedlist>
</para>        </inbodydescription>
