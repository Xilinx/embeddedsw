</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>PcrBuf</parametername>
</parameternamelist>
<parameterdescription>
<para>- Pointer to the PCR buffer to store the requested PCR contents </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>PcrBufSize</parametername>
</parameternamelist>
<parameterdescription>
<para>- Buffer size to read the PCR values</para></parameterdescription>
</parameteritem>
</parameterlist>
