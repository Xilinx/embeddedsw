        <type>int</type>
        <definition>int XOcp_GenDmeResp</definition>
        <argsstring>(XOcp_ClientInstance *InstancePtr, u64 NonceAddr, u64 DmeStructResAddr)</argsstring>
        <name>XOcp_GenDmeResp</name>
        <param>
          <type><ref refid="struct_x_ocp___client_instance" kindref="compound">XOcp_ClientInstance</ref> *</type>
          <declname>InstancePtr</declname>
        </param>
        <param>
