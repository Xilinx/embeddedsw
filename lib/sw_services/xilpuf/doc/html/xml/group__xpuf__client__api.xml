      <memberdef kind="function" id="group__xpuf__client__api_1gad52ef96e7928d55f964e2169dfb527de" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>int</type>
        <definition>int XPuf_SendRequest</definition>
        <argsstring>(const XPuf_ClientInstance *InstancePtr, u32 *PayloadBuf, u32 PayloadLen, u32 *ResponseBuf, u32 ResponseLen)</argsstring>
        <name>XPuf_SendRequest</name>
        <param>
          <type>const <ref refid="struct_x_puf___client_instance" kindref="compound">XPuf_ClientInstance</ref> *</type>
          <declname>InstancePtr</declname>
        </param>
        <param>
          <type>u32 *</type>
          <declname>PayloadBuf</declname>
        </param>
        <param>
          <type>u32</type>
          <declname>PayloadLen</declname>
        </param>
        <param>
          <type>u32 *</type>
          <declname>ResponseBuf</declname>
        </param>
        <param>
          <type>u32</type>
          <declname>ResponseLen</declname>
        </param>
        <briefdescription>
<para>This function sends request to PLM through either SMC or IPI mailbox based on the execution environment. </para>        </briefdescription>
        <detaileddescription>
<para>For EL1 non-secure AArch64 applications, SMC is used. For other environments, IPI mailbox is used.</para><para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>InstancePtr</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to the client instance </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>PayloadBuf</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to the payload message </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>PayloadLen</parametername>
</parameternamelist>
<parameterdescription>
<para>Length of the payload message </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>ResponseBuf</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to store response values (can be NULL) </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>ResponseLen</parametername>
</parameternamelist>
<parameterdescription>
<para>Length of response buffer (number of u32 elements)</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para><itemizedlist>
<listitem><para>XST_SUCCESS if the request is successful</para></listitem><listitem><para>XST_FAILURE if there is a failure</para></listitem><listitem><para>XST_INVALID_PARAM if input parameters are invalid</para></listitem></itemizedlist>
</para></simplesect>
<simplesect kind="note"><para>This is a generic API that internally handles SMC or Mailbox communication based on the build configuration. </para></simplesect>
</para>        </detaileddescription>
        <inbodydescription>
<para><itemizedlist>
<listitem><para>Validate input parameters.</para></listitem><listitem><para>For other environments, use IPI mailbox communication.</para></listitem><listitem><para>Validate mailbox pointer for IPI communication</para></listitem><listitem><para>Send request through IPI mailbox</para></listitem><listitem><para>Note: For communication via IPI mailbox, response is not directly returned. The caller should handle response retrieval if needed.</para></listitem></itemizedlist>
</para>        </inbodydescription>
