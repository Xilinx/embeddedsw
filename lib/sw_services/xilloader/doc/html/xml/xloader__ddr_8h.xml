        <type>int</type>
        <definition>int XLoader_DdrInit</definition>
        <argsstring>(u32 DeviceFlags)</argsstring>
        <name>XLoader_DdrInit</name>
        <param>
          <type>u32</type>
          <declname>DeviceFlags</declname>
        </param>
        <briefdescription>
<para>This function is used to initialize for DDR init. </para>        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>DeviceFlags</parametername>
</parameternamelist>
<parameterdescription>
<para>Loader init prototype requires flags</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para><itemizedlist>
<listitem><para>XST_SUCCESS on success</para></listitem><listitem><para>XLOADER_ERR_PM_DEV_DDR_0 on device request to DDR fail. </para></listitem></itemizedlist>
</para></simplesect>
</para>        </detaileddescription>
        <inbodydescription>
<para><itemizedlist>
<listitem><para>Initialize the device request for DDR_0.</para></listitem><listitem><para>Otherwise return XLOADER_ERR_PM_DEV_DDR_0.</para></listitem></itemizedlist>
</para>        </inbodydescription>
