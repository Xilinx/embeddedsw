        <type>int</type>
        <definition>int XLoader_SendRequest</definition>
        <argsstring>(XLoader_ClientInstance *InstancePtr, u32 *PayloadBuf, u32 PayloadLen, u32 *ResponseBuf, u32 ResponseLen)</argsstring>
        <name>XLoader_SendRequest</name>
        <param>
          <type><ref refid="struct_x_loader___client_instance" kindref="compound">XLoader_ClientInstance</ref> *</type>
          <declname>InstancePtr</declname>
        </param>
        <param>
          <type>u32 *</type>
          <declname>PayloadBuf</declname>
        </param>
        <param>
          <type>u32</type>
          <declname>PayloadLen</declname>
        </param>
        <param>
          <type>u32 *</type>
