</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>KeyLen</parametername>
</parameternamelist>
<parameterdescription>
<para>variable holds the length of the key </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>KeyOut</parametername>
</parameternamelist>
<parameterdescription>
<para>is the variable which holds the output key buffer&apos;s address </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>KeyOutLen</parametername>
</parameternamelist>
<parameterdescription>
<para>is the variable which specifies the output key length based on SHA mode</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para><itemizedlist>
<listitem><para>XST_SUCCESS - If initialization was successful.</para></listitem><listitem><para>XST_FAILURE - On failure. </para></listitem></itemizedlist>
</para></simplesect>
</para>        </detaileddescription>
