        <briefdescription>
<para>This function sends IPI request to generate SHA3 digest. </para>        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>InstancePtr</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to the XSecure_ClientInstance structure. </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>Sha3Params</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to the <ref refid="struct_x_secure___sha_op_params" kindref="compound">XSecure_ShaOpParams</ref> structure which holds parameters of SHA input arguments.</para></parameterdescription>
</parameteritem>
</parameterlist>
