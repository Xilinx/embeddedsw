</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>ShaInstancePtr</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to the SHA instance used during OAEP encoding for MGF </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>Shatype</parametername>
</parameternamelist>
<parameterdescription>
<para>is SHA algorithm type used for MGF</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para><itemizedlist>
<listitem><para>XST_SUCCESS On Success</para></listitem><listitem><para>XST_INVALID_PARAM If any input parameter is invalid</para></listitem><listitem><para>XSECURE_RSA_PWCT_MEM_CMP_FAILED_ERROR If RSA pwct comparison fails</para></listitem><listitem><para>XST_FAILURE On Failure </para></listitem></itemizedlist>
</para></simplesect>
</para>        </detaileddescription>
