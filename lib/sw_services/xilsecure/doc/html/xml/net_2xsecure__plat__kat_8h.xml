<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>PrivKey</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to the <ref refid="struct_x_secure___rsa_key" kindref="compound">XSecure_RsaKey</ref> </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>PubKey</parametername>
</parameternamelist>
<parameterdescription>
