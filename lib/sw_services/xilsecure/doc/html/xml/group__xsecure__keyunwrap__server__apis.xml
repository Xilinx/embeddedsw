        <type>int</type>
        <definition>static int XSecure_UpdateKeySlotStatusAddr</definition>
        <argsstring>(void)</argsstring>
        <name>XSecure_UpdateKeySlotStatusAddr</name>
        <param>
          <type>void</type>
        </param>
        <briefdescription>
<para>This function updates the key free slot status address. </para>        </briefdescription>
        <detaileddescription>
<para><simplesect kind="return"><para><itemizedlist>
<listitem><para>XST_SUCCESS - On success.</para></listitem><listitem><para>XSECURE_ERR_KEY_STORE_SIZE - If key store size is invalid.</para></listitem><listitem><para>XSECURE_ERR_NO_FREE_KEY_SLOT - If there is no free key slot.</para></listitem><listitem><para>XST_FAILURE - On failure. </para></listitem></itemizedlist>
</para></simplesect>
</para>        </detaileddescription>
        <inbodydescription>
<para><itemizedlist>
<listitem><para>Check if the key store size is valid</para></listitem><listitem><para>Calculate the starting address of the free key slot status</para></listitem><listitem><para>Iterate through the key slots to find a free slot</para></listitem><listitem><para>Move to the next slot</para></listitem><listitem><para>Wrap around if the end of the key store is reached </para></listitem></itemizedlist>
</para>        </inbodydescription>
        <location file="/proj/xhdsswstaff1/bhawanas/patch_integration/auto_jobs/esw_github_doxy/git/2026.1/embeddedsw/lib/sw_services/xilsecure/src/server/core/key_unwrap/xsecure_keyunwrap.c" line="80" column="1" bodyfile="/proj/xhdsswstaff1/bhawanas/patch_integration/auto_jobs/esw_github_doxy/git/2026.1/embeddedsw/lib/sw_services/xilsecure/src/server/core/key_unwrap/xsecure_keyunwrap.c" bodystart="106" bodyend="150"/>
