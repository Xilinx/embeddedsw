      <sectiondef kind="func">
      <memberdef kind="function" id="group__xsecure__slhdsa__server__apis_1ga63a83a36cf727551fc0e1f69fef4e9b6" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>int</type>
        <definition>int XSecure_SlhdsaHtVerify</definition>
        <argsstring>(const u8 *const M, const u64 SignHtAddr, const u64 PublicKeyAddr, const XSecure_SlhdsaHtIndices *const HtIndices)</argsstring>
        <name>XSecure_SlhdsaHtVerify</name>
        <param>
          <type>const u8 *const</type>
          <declname>M</declname>
        </param>
        <param>
          <type>const u64</type>
          <declname>SignHtAddr</declname>
        </param>
        <param>
          <type>const u64</type>
          <declname>PublicKeyAddr</declname>
        </param>
        <param>
          <type>const <ref refid="struct_x_secure___slhdsa_ht_indices" kindref="compound">XSecure_SlhdsaHtIndices</ref> *const</type>
