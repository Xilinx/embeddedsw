        <name>XSecure_SendRequest</name>
        <param>
          <type>const XSecure_ClientInstance *</type>
          <declname>InstancePtr</declname>
        </param>
        <param>
          <type>u32 *</type>
          <declname>PayloadBuf</declname>
        </param>
        <param>
          <type>u32</type>
