      <memberdef kind="function" id="group__xsecure__kdf__server__apis_1ga4ce6b83111541227a82cb8f566a02106" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>int</type>
        <definition>int XSecure_Hkdf</definition>
        <argsstring>(XSecure_KdfParams *InDataPtr, u8 *KdfOut, u32 KdfOutLen)</argsstring>
        <name>XSecure_Hkdf</name>
        <param>
          <type><ref refid="struct_x_secure___kdf_params" kindref="compound">XSecure_KdfParams</ref> *</type>
          <declname>InDataPtr</declname>
        </param>
        <param>
          <type>u8 *</type>
          <declname>KdfOut</declname>
        </param>
        <param>
          <type>u32</type>
          <declname>KdfOutLen</declname>
        </param>
        <briefdescription>
<para>This function performs the HMAC based KDF. </para>        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>InDataPtr</parametername>
</parameternamelist>
<parameterdescription>
<para>is a pointer to the <ref refid="struct_x_secure___kdf_params" kindref="compound">XSecure_KdfParams</ref> instance. one should initialize the structure with following parameters before calling this API.<itemizedlist>
<listitem><para>Key - Is a pointer to the key<itemizedlist>
<listitem><para>KeyLen - length of key pointer</para></listitem><listitem><para>Context - Is a pointer to the context for KDF</para></listitem><listitem><para>ContextLen - Specifies the length of the context pointer. </para></listitem></itemizedlist>
</para></listitem></itemizedlist>
</para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>KdfOut</parametername>
</parameternamelist>
<parameterdescription>
<para>is the pointer to output storage. </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>KdfOutLen</parametername>
</parameternamelist>
<parameterdescription>
<para>is the size of output.</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para><itemizedlist>
<listitem><para>XST_SUCCESS - On success</para></listitem><listitem><para>XSECURE_ERR_HKDF_INVALID_PARAM - If input parameters are invalid</para></listitem><listitem><para>XST_FAILURE - On failure </para></listitem></itemizedlist>
</para></simplesect>
</para>        </detaileddescription>
        <inbodydescription>
<para><itemizedlist>
<listitem><para>Validate input parameters.</para></listitem><listitem><para>Calculate number of iterations based on HKDF output key length and SHA hash length.</para></listitem><listitem><para>Calculate HMAC and form KdfInput</para></listitem><listitem><para>Update block index of 1 byte to HMAC.</para></listitem><listitem><para>Update Context</para></listitem><listitem><para>Get final HMAC</para></listitem><listitem><para>HMAC output size is the SHA algorithm hash length. HKDF key output can be any length.</para></listitem><listitem><para>In the last iteration, data to be copied to the destination can be less than or equal to SHA algorithm hash length which varies based on the requested key output length.</para></listitem><listitem><para>Copy the final HMAC of each iteration to the destination key output buffer.</para></listitem><listitem><para>Verify loop index is within expected bounds </para></listitem></itemizedlist>
</para>        </inbodydescription>
