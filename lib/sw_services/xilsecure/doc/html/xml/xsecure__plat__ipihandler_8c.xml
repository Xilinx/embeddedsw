        <briefdescription>
<para>This function handler calls XSecure_RsaInitialize and XSecure_RsaPrivateDecrypt server APIs. </para>        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>SubsystemId</parametername>
</parameternamelist>
<parameterdescription>
<para>- Subsystem ID. </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>SrcAddrLow</parametername>
</parameternamelist>
<parameterdescription>
<para>- Lower 32 bit address of the <ref refid="struct_x_secure___rsa_in_param" kindref="compound">XSecure_RsaInParam</ref> structure </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>SrcAddrHigh</parametername>
</parameternamelist>
<parameterdescription>
<para>- Higher 32 bit address of the <ref refid="struct_x_secure___rsa_in_param" kindref="compound">XSecure_RsaInParam</ref> structure </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>DstAddrLow</parametername>
</parameternamelist>
<parameterdescription>
<para>- Lower 32 bit address of the output data where decrypted data to be stored </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>DstAddrHigh</parametername>
</parameternamelist>
<parameterdescription>
<para>- Higher 32 bit address of the output data where decrypted data to be stored</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para><itemizedlist>
<listitem><para>XST_SUCCESS If the Rsa decryption is successful</para></listitem><listitem><para>XST_FAILURE If there is a failure </para></listitem></itemizedlist>
</para></simplesect>
</para>        </detaileddescription>
