        <type>int</type>
        <definition>int XSecure_KatIpiHandler</definition>
        <argsstring>(XPlmi_Cmd *Cmd)</argsstring>
        <name>XSecure_KatIpiHandler</name>
        <param>
          <type>XPlmi_Cmd *</type>
          <declname>Cmd</declname>
        </param>
        <briefdescription>
<para>This function calls respective IPI handler based on the API_ID. </para>        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>Cmd</parametername>
</parameternamelist>
<parameterdescription>
<para>is a pointer to the command structure</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para><itemizedlist>
<listitem><para>XST_SUCCESS - If the handler execution is successful</para></listitem><listitem><para>XST_INVALID_PARAM - If Cmd is NULL or invalid API ID is received.</para></listitem><listitem><para>XST_FAILURE - If there is a failure </para></listitem></itemizedlist>
</para></simplesect>
</para>        </detaileddescription>
        <inbodydescription>
<para><itemizedlist>
<listitem><para>Call the respective API handler according to API ID</para></listitem><listitem><para>XSecure_AesDecKat</para></listitem><listitem><para>XSecure_AesDecCmKat</para></listitem><listitem><para>XSecure_AesEncKat</para></listitem><listitem><para>XSecure_RsaPubEncKat</para></listitem><listitem><para>XSecure_RsaPrivateDecKat</para></listitem><listitem><para>XSecure_EllipticSignVerifyKat</para></listitem><listitem><para>XSecure_EllipticSignGenKat</para></listitem><listitem><para>XSecure_ShaKat</para></listitem><listitem><para>SHA IPI event handling </para></listitem></itemizedlist>
</para>        </inbodydescription>
