      <memberdef kind="function" id="trngpsx_2xsecure__trng__ipihandler_8c_1gabf2d87d030229083f287ee96b2306640" prot="public" static="yes" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>int</type>
        <definition>static int XSecure_TrngGenerateRandNum</definition>
        <argsstring>(u32 SrcAddrLow, u32 SrcAddrHigh, u32 Size)</argsstring>
        <name>XSecure_TrngGenerateRandNum</name>
        <param>
          <type>u32</type>
          <declname>SrcAddrLow</declname>
        </param>
        <param>
          <type>u32</type>
          <declname>SrcAddrHigh</declname>
        </param>
        <param>
          <type>u32</type>
          <declname>Size</declname>
        </param>
        <briefdescription>
<para>This function handler extracts the payload params with respect to XSECURE_API_TRNG_GENERATE IPI command and calls XSecure_GetRandomNum server API to generate random number. </para>        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>SrcAddrLow</parametername>
</parameternamelist>
<parameterdescription>
<para>Lower 32 bit address of the random data buffer address. </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>SrcAddrHigh</parametername>
</parameternamelist>
<parameterdescription>
<para>Higher 32 bit address of the random data buffer address. </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>Size</parametername>
</parameternamelist>
<parameterdescription>
<para>Number of random bytes needs to be generated.</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para><itemizedlist>
<listitem><para>XST_SUCCESS - If the generate is successful</para></listitem><listitem><para>XTRNGPSX_INVALID_BUF_SIZE - If input size is invalid.</para></listitem><listitem><para>XST_FAILURE - If there is a failure </para></listitem></itemizedlist>
</para></simplesect>
</para>        </detaileddescription>
