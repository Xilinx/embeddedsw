        <type>int</type>
        <definition>int XSecure_GenSharedSecret</definition>
        <argsstring>(XSecure_ClientInstance *InstancePtr, u32 CrvType, const u8 *PrivateKey, const u8 *PublicKey, u8 *SharedSecret)</argsstring>
        <name>XSecure_GenSharedSecret</name>
        <param>
          <type>XSecure_ClientInstance *</type>
          <declname>InstancePtr</declname>
        </param>
        <param>
          <type>u32</type>
          <declname>CrvType</declname>
        </param>
        <param>
          <type>const u8 *</type>
          <declname>PrivateKey</declname>
        </param>
        <param>
