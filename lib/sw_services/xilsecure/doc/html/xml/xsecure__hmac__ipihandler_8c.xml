        <type>int</type>
        <definition>static int XSecure_HmacOperation</definition>
        <argsstring>(u32 SubsystemId, u32 SrcAddrLow, u32 SrcAddrHigh, u32 ParamsSize)</argsstring>
        <name>XSecure_HmacOperation</name>
        <param>
          <type>u32</type>
          <declname>SubsystemId</declname>
        </param>
        <param>
          <type>u32</type>
          <declname>SrcAddrLow</declname>
        </param>
        <param>
          <type>u32</type>
          <declname>SrcAddrHigh</declname>
        </param>
        <param>
          <type>u32</type>
          <declname>ParamsSize</declname>
        </param>
        <briefdescription>
<para>This function performs HMAC operation. </para>        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>SubsystemId</parametername>
</parameternamelist>
<parameterdescription>
<para>Subsystem ID </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>SrcAddrLow</parametername>
</parameternamelist>
<parameterdescription>
<para>Lower 32 bit address of the <ref refid="struct_x_secure___hmac_params" kindref="compound">XSecure_HmacParams</ref> structure </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>SrcAddrHigh</parametername>
</parameternamelist>
<parameterdescription>
<para>Higher 32 bit address of the <ref refid="struct_x_secure___hmac_params" kindref="compound">XSecure_HmacParams</ref> structure </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>ParamsSize</parametername>
</parameternamelist>
<parameterdescription>
<para>Size in bytes of the <ref refid="struct_x_secure___hmac_params" kindref="compound">XSecure_HmacParams</ref> structure as reported by the client</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para><itemizedlist>
<listitem><para>XST_SUCCESS On Success</para></listitem><listitem><para>XSECURE_HMAC_INVALID_PARAM If any input parameter is invalid</para></listitem><listitem><para>XST_FAILURE On failure </para></listitem></itemizedlist>
</para></simplesect>
</para>        </detaileddescription>
        <inbodydescription>
<para><itemizedlist>
<listitem><para>Validate the size passed by the client matches the expected parameter structure size and is 8-byte aligned</para></listitem><listitem><para>Validate internal address fields in the copied structure</para></listitem><listitem><para>Ensure the client supplied output buffer is large enough to hold the HMAC result before validating its address range</para></listitem></itemizedlist>
</para>        </inbodydescription>
