        <argsstring>(XSecure_ClientInstance *InstancePtr, const u64 KeyAddr, const u64 InDataAddr, const u32 Size, const u64 OutDataAddr)</argsstring>
        <name>XSecure_RsaPrivateDecrypt</name>
        <param>
          <type>XSecure_ClientInstance *</type>
          <declname>InstancePtr</declname>
        </param>
        <param>
          <type>const u64</type>
          <declname>KeyAddr</declname>
        </param>
        <param>
          <type>const u64</type>
          <declname>InDataAddr</declname>
        </param>
        <param>
          <type>const u32</type>
          <declname>Size</declname>
        </param>
        <param>
          <type>const u64</type>
          <declname>OutDataAddr</declname>
