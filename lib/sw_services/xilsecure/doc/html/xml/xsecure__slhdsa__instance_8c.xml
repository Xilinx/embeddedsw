        <argsstring>(void)</argsstring>
        <name>XSecure_SlhdsaGetInstance</name>
        <param>
          <type>void</type>
        </param>
        <briefdescription>
<para>This function returns the <ref refid="struct_x_secure___slhdsa_instance" kindref="compound">XSecure_SlhdsaInstance</ref> instance. </para>        </briefdescription>
        <detaileddescription>
<para><verbatim>            SlhdsaInstance stores all required components for SLH-DSA signature verification.
</verbatim></para><para><simplesect kind="return"><para>Returns pointer to <ref refid="struct_x_secure___slhdsa_instance" kindref="compound">XSecure_SlhdsaInstance</ref> instance </para></simplesect>
</para>        </detaileddescription>
        <inbodydescription>
<para><itemizedlist>
<listitem><para>SLH-DSA-SHAKE-256s (see FIPS 205 Table 2) Formula calculations: n=32, lgw=4, len1=ceil(8*32/4)=64, len2=3, len=67</para></listitem><listitem><para>len1 = ceil(8*n/lgw) = ceil(8*32/4) = 64</para></listitem><listitem><para>len2 = 3 checksum digits</para></listitem><listitem><para>ceil((len2*lgw)/8) = ceil(12/8) = 2 bytes</para></listitem></itemizedlist>
</para>        </inbodydescription>
