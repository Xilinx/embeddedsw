      <memberdef kind="function" id="group__xsecure__mldsa__server__apis_1ga3291e37182d3193146f622c0477b15be" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>int</type>
        <definition>int XSecure_MldsaSignVerify</definition>
        <argsstring>(const XSecure_MldsaSignVerifyParams *MldsaParams)</argsstring>
        <name>XSecure_MldsaSignVerify</name>
        <param>
          <type>const <ref refid="struct_x_secure___mldsa_sign_verify_params" kindref="compound">XSecure_MldsaSignVerifyParams</ref> *</type>
          <declname>MldsaParams</declname>
        </param>
        <briefdescription>
<para>This function verifies MLDSA signature for the given data using the provided public key and context. </para>        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>MldsaParams</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to MLDSA signature verification parameters instance.</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para><itemizedlist>
<listitem><para>XST_SUCCESS On successful verification.</para></listitem><listitem><para>Error code On failure. </para></listitem></itemizedlist>
</para></simplesect>
</para>        </detaileddescription>
        <inbodydescription>
<para><itemizedlist>
<listitem><para>Validate MLDSA instance pointer</para></listitem><listitem><para>Validate ctx length</para></listitem><listitem><para>Check that first 64 bytes of signature are not all zeros (CT validation)</para></listitem><listitem><para>Release MLDSA from reset</para></listitem><listitem><para>Wait for the core to be ready for processing inputs</para></listitem><listitem><para>Write context length to context config register</para></listitem><listitem><para>Transfer context to hardware registers</para></listitem><listitem><para>Transfer public key to hardware registers</para></listitem><listitem><para>Transfer signature to hardware registers</para></listitem><listitem><para>Transfer word-aligned portion (4624 bytes = 1156 words)</para></listitem><listitem><para>Handle last 3 bytes using intermediate word buffer</para></listitem><listitem><para>Configure ML-DSA for signature verification with streaming message mode</para></listitem><listitem><para>Wait for the core to be ready to receive the message in streaming mode</para></listitem><listitem><para>Transfer message/data to hardware registers</para></listitem><listitem><para>Wait for signature verification operation to complete</para></listitem><listitem><para>Compare generated result with expected signature&apos;s CT component</para></listitem><listitem><para>Clear ML-DSA control registers (using ZEROIZE command) to remove sensitive data from hardware for security</para></listitem><listitem><para>Wait for zeroize operation to complete</para></listitem><listitem><para>Put MLDSA into reset state </para></listitem></itemizedlist>
</para>        </inbodydescription>
