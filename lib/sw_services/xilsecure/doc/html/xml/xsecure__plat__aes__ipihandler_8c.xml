        <type>int</type>
        <definition>static int XSecure_AesPerformOperationAndZeroizeKey</definition>
        <argsstring>(u32 SubsystemId, u32 AesParamsAddrLow, u32 AesParamsAddrHigh, u32 KeyAddrLow, u32 KeyAddrHigh)</argsstring>
        <name>XSecure_AesPerformOperationAndZeroizeKey</name>
        <param>
          <type>u32</type>
          <declname>SubsystemId</declname>
        </param>
        <param>
          <type>u32</type>
          <declname>AesParamsAddrLow</declname>
        </param>
        <param>
          <type>u32</type>
          <declname>AesParamsAddrHigh</declname>
        </param>
        <param>
          <type>u32</type>
          <declname>KeyAddrLow</declname>
        </param>
        <param>
          <type>u32</type>
          <declname>KeyAddrHigh</declname>
        </param>
        <briefdescription>
<para>This function performs below operation: </para>        </briefdescription>
        <detaileddescription>
<para><verbatim>            - Write key into the key source provided by the user
            - Encrypt/decrypt a single block of data using the provided key
            - Zeroize the key once the AES operation is done
</verbatim></para><para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>SubsystemId</parametername>
</parameternamelist>
<parameterdescription>
<para>Subsystem ID. </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>AesParamsAddrLow</parametername>
</parameternamelist>
<parameterdescription>
<para>Lower 32 bit address of the <ref refid="struct_x_secure___aes_data_block_params" kindref="compound">XSecure_AesDataBlockParams</ref> structure. </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>AesParamsAddrHigh</parametername>
</parameternamelist>
<parameterdescription>
<para>Upper 32 bit address of the <ref refid="struct_x_secure___aes_data_block_params" kindref="compound">XSecure_AesDataBlockParams</ref> structure. </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>KeyAddrLow</parametername>
</parameternamelist>
<parameterdescription>
<para>Lower 32 bit address of the buffer which stores the key </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>KeyAddrHigh</parametername>
</parameternamelist>
<parameterdescription>
<para>Upper 32 bit address of the buffer which stores the key</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para><itemizedlist>
<listitem><para>XST_SUCCESS In case of success</para></listitem><listitem><para>XST_FAILURE In case of failure </para></listitem></itemizedlist>
</para></simplesect>
</para>        </detaileddescription>
