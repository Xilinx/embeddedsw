        <type>int</type>
        <definition>int XSecure_MldsaSignVerifyClient</definition>
        <argsstring>(XSecure_ClientInstance *InstancePtr, u64 MldsaParamAddr)</argsstring>
        <name>XSecure_MldsaSignVerifyClient</name>
        <param>
          <type>XSecure_ClientInstance *</type>
          <declname>InstancePtr</declname>
        </param>
        <param>
          <type>u64</type>
          <declname>MldsaParamAddr</declname>
        </param>
        <briefdescription>
<para>This function sends IPI request to verify MLDSA signature for a given data. </para>        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>InstancePtr</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to the client instance </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>MldsaParamAddr</parametername>
</parameternamelist>
<parameterdescription>
<para>Address of <ref refid="struct_x_secure___mldsa_sign_verify_params" kindref="compound">XSecure_MldsaSignVerifyParams</ref> structure</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para><itemizedlist>
<listitem><para>XST_SUCCESS On success</para></listitem><listitem><para>XST_FAILURE On failure </para></listitem></itemizedlist>
</para></simplesect>
</para>        </detaileddescription>
        <inbodydescription>
<para><itemizedlist>
<listitem><para>Perform input parameter validation on InstancePtr. Return XST_FAILURE if input parameters are invalid</para></listitem><listitem><para>Fill IPI Payload</para></listitem><listitem><para>Send an IPI request to the PLM by using the CDO command to call XSecure_MldsaSignVerify API and returns the status of the IPI response.</para></listitem></itemizedlist>
</para>        </inbodydescription>
