        <type>void</type>
        <definition>void XSecure_SlhdsaBase2b</definition>
        <argsstring>(u32 *const BaseB, const u8 *const X, const u32 b, const u32 OutLen)</argsstring>
        <name>XSecure_SlhdsaBase2b</name>
        <param>
          <type>u32 *const</type>
          <declname>BaseB</declname>
        </param>
        <param>
          <type>const u8 *const</type>
          <declname>X</declname>
        </param>
        <param>
          <type>const u32</type>
          <declname>b</declname>
