</para><simplesectsep/><para><itemizedlist>
<listitem><para>XST_SUCCESS On success</para></listitem><listitem><para>XSECURE_RSA_KAT_DECRYPT_DATA_MISMATCH_ERROR Error when RSA data not matched with expected data</para></listitem><listitem><para>XST_FAILURE On failure </para></listitem></itemizedlist>
</para></simplesect>
</para>        </detaileddescription>
