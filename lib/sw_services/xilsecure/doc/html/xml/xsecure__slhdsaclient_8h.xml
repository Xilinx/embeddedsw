        <type>int</type>
        <definition>int XSecure_SlhdsaSignVerifyClient</definition>
        <argsstring>(XSecure_ClientInstance *InstancePtr, u64 SlhdsaParamAddr)</argsstring>
        <name>XSecure_SlhdsaSignVerifyClient</name>
        <param>
          <type>XSecure_ClientInstance *</type>
          <declname>InstancePtr</declname>
        </param>
        <param>
          <type>u64</type>
          <declname>SlhdsaParamAddr</declname>
