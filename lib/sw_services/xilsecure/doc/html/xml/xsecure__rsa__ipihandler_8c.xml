        <argsstring>(u32 SubsystemId, u32 SrcAddrLow, u32 SrcAddrHigh, u32 DstAddrLow, u32 DstAddrHigh)</argsstring>
        <name>XSecure_RsaEncrypt</name>
        <param>
          <type>u32</type>
          <declname>SubsystemId</declname>
        </param>
        <param>
          <type>u32</type>
          <declname>SrcAddrLow</declname>
