      <sectiondef kind="func">
      <memberdef kind="function" id="group__xsecure__slhdsa__server__apis_1ga141cd483445e9c483f9e89b1958e8d79" prot="public" static="yes" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void</type>
        <definition>static void XSecure_ComputeChecksum</definition>
        <argsstring>(const XSecure_ChecksumParam *const ChecksumParams, const u8 *const M, u32 *const Output)</argsstring>
        <name>XSecure_ComputeChecksum</name>
        <param>
          <type>const <ref refid="struct_x_secure___checksum_param" kindref="compound">XSecure_ChecksumParam</ref> *const</type>
          <declname>ChecksumParams</declname>
        </param>
        <param>
          <type>const u8 *const</type>
          <declname>M</declname>
        </param>
        <param>
          <type>u32 *const</type>
          <declname>Output</declname>
        </param>
        <briefdescription>
<para>This function computes WOTS+ checksum and combines with base-w message representation to create the complete message array used for WOTS+ signature verification. </para>        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>ChecksumParams</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to checksum parameters structure containing: </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>M</parametername>
</parameternamelist>
<parameterdescription>
<para>Input message (n bytes, typically 32 bytes for SHAKE-256s) </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>Output</parametername>
</parameternamelist>
<parameterdescription>
<para>Output array to store combined message and checksum digits (len1 + len2 elements, typically 67 for SHAKE-256s) </para></parameterdescription>
</parameteritem>
</parameterlist>
</para>        </detaileddescription>
        <inbodydescription>
<para><itemizedlist>
<listitem><para>Buffer to hold checksum as bytes (max 4 bytes needed)</para></listitem><listitem><para>Step 2: msg &lt;- base_2b(M, lgw, len1) - Convert message to base-w</para></listitem><listitem><para>Step 3-5: Compute checksum</para></listitem><listitem><para>for i from 0 to len1 - 1 do</para></listitem><listitem><para>Step 4: csum &lt;- csum + w - 1 - msg[i]</para></listitem><listitem><para>w = 2^lgw, so w-1 = (1 &lt;&lt; lgw) - 1</para></listitem><listitem><para>Step 5: end for</para></listitem><listitem><para>Step 6: csum &lt;- csum &lt;&lt; ((8 - ((len2 * lgw) mod 8)) mod 8)</para></listitem><listitem><para>For lgw=4, this shifts left by 4 bits</para></listitem><listitem><para>Convert checksum to bytes for base_2b conversion</para></listitem><listitem><para>toByte(csum, ceil(len2*lgw/8))</para></listitem><listitem><para>Store checksum in big-endian format</para></listitem><listitem><para>Step 7: msg &lt;- msg || base_2b(toByte(csum, ceil(len2*lgw/8)), lgw, len2)</para></listitem><listitem><para>Convert checksum to base-w and append to message array </para></listitem></itemizedlist>
</para>        </inbodydescription>
        <location file="/proj/xhdsswstaff1/bhawanas/patch_integration/auto_jobs/esw_github_doxy/git/2026.1/embeddedsw/lib/sw_services/xilsecure/src/server/core/slhdsa/xsecure_slhdsa_wots.c" line="36" column="1" bodyfile="/proj/xhdsswstaff1/bhawanas/patch_integration/auto_jobs/esw_github_doxy/git/2026.1/embeddedsw/lib/sw_services/xilsecure/src/server/core/slhdsa/xsecure_slhdsa_wots.c" bodystart="55" bodyend="92"/>
