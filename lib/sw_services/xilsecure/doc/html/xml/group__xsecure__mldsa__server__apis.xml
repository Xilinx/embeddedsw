        <type>void</type>
        <definition>static void XSecure_MldsaMsgTransferToCore</definition>
        <argsstring>(u64 DataAddr, u32 DataLen)</argsstring>
        <name>XSecure_MldsaMsgTransferToCore</name>
        <param>
          <type>u64</type>
          <declname>DataAddr</declname>
        </param>
        <param>
          <type>u32</type>
          <declname>DataLen</declname>
        </param>
        <briefdescription>
<para>This function transfers message/data to the ML-DSA hardware core in streaming mode. </para>        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>DataAddr</parametername>
</parameternamelist>
<parameterdescription>
<para>64-bit address of the message/data to be transferred. </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>DataLen</parametername>
</parameternamelist>
<parameterdescription>
<para>Length of the message/data in bytes.</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>None </para></simplesect>
</para>        </detaileddescription>
        <inbodydescription>
<para><itemizedlist>
<listitem><para>Transfer message/data to hardware registers</para></listitem><listitem><para>Stream full words to hardware</para></listitem><listitem><para>Handle last partial word if present</para></listitem><listitem><para>If last message word is not 32-bit aligned, set strobe according to valid bytes in the last message word</para></listitem><listitem><para>If last message word is 32-bit aligned, indicate end with zero strobe</para></listitem><listitem><para>Stream last partial message word to hardware </para></listitem></itemizedlist>
</para>        </inbodydescription>
