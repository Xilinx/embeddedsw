      <memberdef kind="function" id="group__xsecure__mldsa__server__apis_1ga46920ff3a1a857a905036689c2bfc115" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>int</type>
        <definition>int XSecure_MldsaSignGenerate</definition>
        <argsstring>(XSecure_MldsaSignGenParams *MldsaParams)</argsstring>
        <name>XSecure_MldsaSignGenerate</name>
        <param>
          <type><ref refid="struct_x_secure___mldsa_sign_gen_params" kindref="compound">XSecure_MldsaSignGenParams</ref> *</type>
          <declname>MldsaParams</declname>
        </param>
        <briefdescription>
<para>This function generates MLDSA signature for the given data using the provided secret key. </para>        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>MldsaParams</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to MLDSA signature generation parameters instance.</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para><itemizedlist>
<listitem><para>XST_SUCCESS On successful signature generation.</para></listitem><listitem><para>Error code On failure. </para></listitem></itemizedlist>
</para></simplesect>
</para>        </detaileddescription>
        <inbodydescription>
<para><itemizedlist>
<listitem><para>Validate MLDSA instance pointer</para></listitem><listitem><para>Validate secret key length</para></listitem><listitem><para>Validate signature buffer length</para></listitem><listitem><para>Generate signing randomness using TRNG (32 bytes)</para></listitem><listitem><para>Generate entropy using TRNG (64 bytes)</para></listitem><listitem><para>Release MLDSA from reset</para></listitem><listitem><para>Wait for the core to be ready (STATUS flag should be 2&apos;b01 or 2&apos;b11)</para></listitem><listitem><para>Feed the required inputs: msg, sk_in, sign_rnd, entropy</para></listitem><listitem><para>Transfer secret key to hardware registers</para></listitem><listitem><para>Transfer signing randomness to hardware registers (256 bits = 32 bytes)</para></listitem><listitem><para>Transfer entropy to hardware registers (512 bits = 64 bytes)</para></listitem><listitem><para>Trigger the core for performing Signing (STATUS flag will be changed to 2&apos;b00)</para></listitem><listitem><para>Configure ML-DSA for signature generation with streaming message mode</para></listitem><listitem><para>Wait for the core to be ready to receive the message in streaming mode</para></listitem><listitem><para>Transfer message/data to hardware registers</para></listitem><listitem><para>Wait for the core to be ready and valid (STATUS flag should be 2&apos;b11)</para></listitem><listitem><para>Read the generated signature from hardware registers</para></listitem><listitem><para>Transfer word-aligned portion (4624 bytes = 1156 words)</para></listitem><listitem><para>Handle last 3 bytes using intermediate word buffer</para></listitem><listitem><para>Clear ML-DSA control registers (using ZEROIZE command) to remove sensitive data from hardware for security</para></listitem><listitem><para>Wait for zeroize operation to complete</para></listitem><listitem><para>Put MLDSA into reset state </para></listitem></itemizedlist>
</para>        </inbodydescription>
