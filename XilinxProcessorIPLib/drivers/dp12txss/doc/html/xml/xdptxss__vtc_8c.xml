</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>MsaConfig</parametername>
</parameternamelist>
<parameterdescription>
<para>is a pointer to main stream attributes structure that will be used to extract timing values. </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>VtcAdjustBs</parametername>
</parameternamelist>
<parameterdescription>
