        <name>DpPsu_PollExample</name>
        <param>
          <type><ref refid="struct_x_dp_psu" kindref="compound">XDpPsu</ref> *</type>
          <declname>InstancePtr</declname>
        </param>
        <param>
          <type>u32</type>
          <declname>BaseAddress</declname>
