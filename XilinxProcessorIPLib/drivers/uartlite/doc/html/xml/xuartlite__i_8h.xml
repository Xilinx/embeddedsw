      <memberdef kind="define" id="group__uartlite_1ga9a29be78566c773a9f1ad81bd3fddb5e" prot="public" static="no">
        <name>XUartLite_UpdateStats</name>
        <param><defname>InstancePtr</defname></param>
        <param><defname>StatusRegister</defname></param>
        <initializer>{								\
	if ((StatusRegister) &amp; XUL_SR_OVERRUN_ERROR)		\
	{							\
		(InstancePtr)-&gt;Stats.ReceiveOverrunErrors++;	\
	}							\
	if ((StatusRegister) &amp; XUL_SR_PARITY_ERROR)		\
	{							\
		(InstancePtr)-&gt;Stats.ReceiveParityErrors++;	\
	}							\
	if ((StatusRegister) &amp; XUL_SR_FRAMING_ERROR)		\
	{							\
		(InstancePtr)-&gt;Stats.ReceiveFramingErrors++;	\
	}							\
}</initializer>
