        <type>s32</type>
        <definition>s32 XI3cPsx_SetSClkRate</definition>
        <argsstring>(XI3cPsx *InstancePtr, u32 SclkHz)</argsstring>
        <name>XI3cPsx_SetSClkRate</name>
        <param>
          <type><ref refid="struct_x_i3c_psx" kindref="compound">XI3cPsx</ref> *</type>
          <declname>InstancePtr</declname>
        </param>
        <param>
          <type>u32</type>
          <declname>SclkHz</declname>
