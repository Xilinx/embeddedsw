      <memberdef kind="function" id="group__iomodule_1gaed5ebecb3c051addf25c38216b08069a" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>s32</type>
        <definition>s32 XIOModule_SetBaudRate</definition>
        <argsstring>(XIOModule *InstancePtr, u32 BaudRate)</argsstring>
        <name>XIOModule_SetBaudRate</name>
        <param>
          <type><ref refid="struct_x_i_o_module" kindref="compound">XIOModule</ref> *</type>
          <declname>InstancePtr</declname>
        </param>
        <param>
          <type>u32</type>
          <declname>BaudRate</declname>
        </param>
        <briefdescription>
<para>Sets the baud rate for the specified UART. </para>        </briefdescription>
        <detaileddescription>
<para>Checks the input value for validity and also verifies that the requested rate can be configured to within the 3 percent error range for RS-232 communications. If the provided rate is not valid, the current setting is unchanged.</para><para>This function is designed to be an internal function only used within the <ref refid="struct_x_i_o_module" kindref="compound">XIOModule</ref> component. It is necessary for initialization and for the user available function that sets the data format.</para><para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>InstancePtr</parametername>
</parameternamelist>
<parameterdescription>
<para>is a pointer to the <ref refid="struct_x_i_o_module" kindref="compound">XIOModule</ref> instance. </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>BaudRate</parametername>
</parameternamelist>
<parameterdescription>
<para>to be set in the hardware.</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para><itemizedlist>
<listitem><para>XST_SUCCESS if everything configures as expected<itemizedlist>
<listitem><para>XST_UART_BAUD_ERROR if the requested rate is not available because there was too much error due to the input clock</para></listitem></itemizedlist>
</para></listitem></itemizedlist>
</para></simplesect>
<simplesect kind="note"><para>None. </para></simplesect>
</para>        </detaileddescription>
