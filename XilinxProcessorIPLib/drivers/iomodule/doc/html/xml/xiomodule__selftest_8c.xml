        <type>int</type>
        <definition>int XIOModule_Intc_SelfTest</definition>
        <argsstring>(XIOModule *InstancePtr)</argsstring>
        <name>XIOModule_Intc_SelfTest</name>
        <param>
          <type><ref refid="struct_x_i_o_module" kindref="compound">XIOModule</ref> *</type>
          <declname>InstancePtr</declname>
        </param>
        <briefdescription>
<para>Run a self-test on the interrupt controller driver/device. </para>        </briefdescription>
        <detaileddescription>
<para>This is a destructive test.</para><para>This involves forcing interrupts into the controller (if possible, given the IO Module configuration) and verifying that they are recognized and can be acknowledged.</para><para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>InstancePtr</parametername>
</parameternamelist>
<parameterdescription>
<para>is a pointer to the <ref refid="struct_x_i_o_module" kindref="compound">XIOModule</ref> instance to be worked on.</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para><itemizedlist>
<listitem><para>XST_SUCCESS if self-test is successful.</para></listitem><listitem><para>XST_INTC_FAIL_SELFTEST if the Interrupt controller fails the self-test. It will fail the self test if the device has previously been started in real mode.</para></listitem></itemizedlist>
</para></simplesect>
<simplesect kind="note"><para>None. </para></simplesect>
</para>        </detaileddescription>
