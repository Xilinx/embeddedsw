</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>VtcAdjustBs</parametername>
</parameternamelist>
<parameterdescription>
<para>is a flag to adjust blanking symbols for reduced blanking timing.</para></parameterdescription>
</parameteritem>
</parameterlist>
