        <definition>int XTMR_Manager_Initialize</definition>
        <argsstring>(XTMR_Manager *InstancePtr, UINTPTR BaseAddr)</argsstring>
        <name>XTMR_Manager_Initialize</name>
        <param>
          <type><ref refid="struct_x_t_m_r___manager" kindref="compound">XTMR_Manager</ref> *</type>
          <declname>InstancePtr</declname>
        </param>
        <param>
