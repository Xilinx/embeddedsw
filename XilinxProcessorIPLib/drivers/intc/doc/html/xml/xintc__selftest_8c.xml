      <memberdef kind="function" id="group__intc_1gaf9a9a16180b363930d21bc94dfe71147" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>int</type>
        <definition>int XIntc_SelfTest</definition>
        <argsstring>(XIntc *InstancePtr)</argsstring>
        <name>XIntc_SelfTest</name>
        <param>
          <type><ref refid="struct_x_intc" kindref="compound">XIntc</ref> *</type>
          <declname>InstancePtr</declname>
        </param>
        <briefdescription>
<para>Run a self-test on the driver/device. </para>        </briefdescription>
        <detaileddescription>
<para>This is a destructive test.</para><para>This involves forcing interrupts into the controller and verifying that they are recognized and can be acknowledged. This test will not succeed if the interrupt controller has been started in real mode such that interrupts cannot be forced.</para><para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>InstancePtr</parametername>
</parameternamelist>
<parameterdescription>
<para>is a pointer to the <ref refid="struct_x_intc" kindref="compound">XIntc</ref> instance to be worked on.</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para><itemizedlist>
<listitem><para>XST_SUCCESS if self-test is successful.</para></listitem><listitem><para>XST_INTC_FAIL_SELFTEST if the Interrupt controller fails the self-test. It will fail the self test if the device has previously been started in real mode.</para></listitem></itemizedlist>
</para></simplesect>
<simplesect kind="note"><para>None. </para></simplesect>
</para>        </detaileddescription>
