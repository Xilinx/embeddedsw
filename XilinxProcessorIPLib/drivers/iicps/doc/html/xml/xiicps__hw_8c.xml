      <memberdef kind="function" id="group__iicps__api_1ga1169a92eb8594d6f038816b5740916f7" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void</type>
        <definition>void XIicPs_Reset</definition>
        <argsstring>(XIicPs *InstancePtr)</argsstring>
        <name>XIicPs_Reset</name>
        <param>
          <type><ref refid="struct_x_iic_ps" kindref="compound">XIicPs</ref> *</type>
          <declname>InstancePtr</declname>
        </param>
        <briefdescription>
<para>Resets the IIC device. </para>        </briefdescription>
        <detaileddescription>
<para>Reset must only be called after the driver has been initialized. The configuration of the device after reset is the same as its configuration after initialization. Any data transfer that is in progress is aborted.</para><para>The upper layer software is responsible for re-configuring (if necessary) and reenabling interrupts for the IIC device after the reset.</para><para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>InstancePtr</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to the <ref refid="struct_x_iic_ps" kindref="compound">XIicPs</ref> instance.</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>None. </para></simplesect>
</para>        </detaileddescription>
