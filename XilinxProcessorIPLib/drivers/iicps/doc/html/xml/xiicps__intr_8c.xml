        <type>void</type>
        <definition>void XIicPs_SetStatusHandler</definition>
        <argsstring>(XIicPs *InstancePtr, void *CallBackRef, XIicPs_IntrHandler FunctionPtr)</argsstring>
        <name>XIicPs_SetStatusHandler</name>
        <param>
          <type><ref refid="struct_x_iic_ps" kindref="compound">XIicPs</ref> *</type>
          <declname>InstancePtr</declname>
        </param>
        <param>
