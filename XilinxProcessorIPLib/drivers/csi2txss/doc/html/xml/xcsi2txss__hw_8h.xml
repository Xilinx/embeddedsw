</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>RegOffset</parametername>
</parameternamelist>
<parameterdescription>
<para>is the register offset of the register (defined at the top of this file) to be written. </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>Data</parametername>
</parameternamelist>
<parameterdescription>
<para>is the 32-bit value to write into the register.</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>None.</para></simplesect>
