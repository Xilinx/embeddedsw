        <type>int</type>
        <definition>int XEmacLite_SelfTest</definition>
        <argsstring>(XEmacLite *InstancePtr)</argsstring>
        <name>XEmacLite_SelfTest</name>
        <param>
          <type><ref refid="struct_x_emac_lite" kindref="compound">XEmacLite</ref> *</type>
          <declname>InstancePtr</declname>
        </param>
        <briefdescription>
<para>Performs a SelfTest on the EmacLite device as follows: </para>        </briefdescription>
        <detaileddescription>
<para><itemizedlist>
<listitem><para>Writes to the mandatory TX buffer and reads back to verify.</para></listitem><listitem><para>If configured, writes to the secondary TX buffer and reads back to verify.</para></listitem><listitem><para>Writes to the mandatory RX buffer and reads back to verify.</para></listitem><listitem><para>If configured, writes to the secondary RX buffer and reads back to verify.</para></listitem></itemizedlist>
</para><para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>InstancePtr</parametername>
</parameternamelist>
<parameterdescription>
<para>is a pointer to the <ref refid="struct_x_emac_lite" kindref="compound">XEmacLite</ref> instance .</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para><itemizedlist>
<listitem><para>XST_SUCCESS if the device Passed the Self Test.<itemizedlist>
<listitem><para>XST_FAILURE if any of the data read backs fail.</para></listitem></itemizedlist>
</para></listitem></itemizedlist>
</para></simplesect>
<simplesect kind="note"><para>None. </para></simplesect>
</para>        </detaileddescription>
