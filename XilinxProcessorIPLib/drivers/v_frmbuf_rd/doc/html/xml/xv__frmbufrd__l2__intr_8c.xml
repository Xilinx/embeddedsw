        <type>int</type>
        <definition>int XVFrmbufRd_SetCallback</definition>
        <argsstring>(XV_FrmbufRd_l2 *InstancePtr, u32 HandlerType, void *CallbackFunc, void *CallbackRef)</argsstring>
        <name>XVFrmbufRd_SetCallback</name>
        <param>
          <type><ref refid="struct_x_v___frmbuf_rd__l2" kindref="compound">XV_FrmbufRd_l2</ref> *</type>
          <declname>InstancePtr</declname>
        </param>
