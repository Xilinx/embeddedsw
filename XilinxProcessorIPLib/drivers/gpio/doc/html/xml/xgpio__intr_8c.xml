      <memberdef kind="function" id="group__gpio__api_1ga116bf1509220aa688f76f80501eb0d9e" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void</type>
        <definition>void XGpio_InterruptGlobalEnable</definition>
        <argsstring>(XGpio *InstancePtr)</argsstring>
        <name>XGpio_InterruptGlobalEnable</name>
        <param>
          <type><ref refid="struct_x_gpio" kindref="compound">XGpio</ref> *</type>
          <declname>InstancePtr</declname>
        </param>
        <briefdescription>
<para>Enables the interrupt output signal. </para>        </briefdescription>
        <detaileddescription>
<para>Interrupts enabled through <ref refid="group__gpio__api_1gaa5b62394f65ecbb6566d91412616509c" kindref="member">XGpio_InterruptEnable()</ref> will not be passed through until the global enable bit is set by this function. This function is designed to allow all interrupts (both channels) to be enabled easily for exiting a critical section. This function will assert if the hardware device has not been built with interrupt capabilities.</para><para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>InstancePtr</parametername>
</parameternamelist>
<parameterdescription>
<para>GPIO instance to operate on.</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>None.</para></simplesect>
<simplesect kind="note"><para>None. </para></simplesect>
</para>        </detaileddescription>
