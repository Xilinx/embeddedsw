      <memberdef kind="function" id="group__gpio__api_1ga8f2cea7ef78412c03c7ebdba87b7cdd4" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void</type>
        <definition>void XGpio_DiscreteSet</definition>
        <argsstring>(XGpio *InstancePtr, unsigned Channel, u32 Mask)</argsstring>
        <name>XGpio_DiscreteSet</name>
        <param>
          <type><ref refid="struct_x_gpio" kindref="compound">XGpio</ref> *</type>
          <declname>InstancePtr</declname>
        </param>
        <param>
          <type>unsigned</type>
          <declname>Channel</declname>
        </param>
        <param>
          <type>u32</type>
          <declname>Mask</declname>
        </param>
        <briefdescription>
<para>Set output discrete(s) to logic 1 for the specified GPIO channel. </para>        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>InstancePtr</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to an <ref refid="struct_x_gpio" kindref="compound">XGpio</ref> instance to be worked on. </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>Channel</parametername>
</parameternamelist>
<parameterdescription>
<para>Contains the channel of the GPIO (1 or 2) to operate on. </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>Mask</parametername>
</parameternamelist>
<parameterdescription>
<para>Set of bits that will be set to 1 in the discrete data register. All other bits in the data register are unaffected.</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>None.</para></simplesect>
<simplesect kind="note"><para></para></simplesect>
The hardware must be built for dual channels if this function is used with any channel other than 1. If it is not, this function will assert.</para><para>This API can only be used if the GPIO_IO ports in the IP are used for connecting to the external output ports. </para>        </detaileddescription>
