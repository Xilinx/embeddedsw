      <memberdef kind="function" id="group__vprocss_1ga35d95efae8c3e41c5c3a6d5d5996efcc" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>u32</type>
        <definition>u32 XVprocSs_GetDrvIndex</definition>
        <argsstring>(UINTPTR BaseAddress)</argsstring>
        <name>XVprocSs_GetDrvIndex</name>
        <param>
          <type>UINTPTR</type>
          <declname>BaseAddress</declname>
        </param>
        <briefdescription>
<para>Retrieves the index of the driver configuration in the XVprocSs_ConfigTable that matches the specified BaseAddress. </para>        </briefdescription>
        <detaileddescription>
<para>This function iterates through the XVprocSs_ConfigTable array and compares each entry&apos;s BaseAddress with the provided BaseAddress. If a match is found, the corresponding index is returned. If no match is found, the function returns the index at which the Name field is NULL (end of the table).</para><para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>BaseAddress</parametername>
</parameternamelist>
<parameterdescription>
<para>The base address to search for in the configuration table.</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>The index of the matching configuration entry in XVprocSs_ConfigTable. If no match is found, returns the index at the end of the table. </para></simplesect>
</para>        </detaileddescription>
