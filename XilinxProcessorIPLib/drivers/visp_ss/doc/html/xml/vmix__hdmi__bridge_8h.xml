      <memberdef kind="function" id="vmix__hdmi__bridge_8h_1a7b08aa9ddf759b04a780216ecf3a5172" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void</type>
        <definition>void VmixHdmiBridge_Cleanup</definition>
        <argsstring>(void)</argsstring>
        <name>VmixHdmiBridge_Cleanup</name>
        <param>
          <type>void</type>
        </param>
        <briefdescription>
<para>Update VMix layer from FBWR callback (live output path) </para>        </briefdescription>
        <detaileddescription>
<para>Called from FBWR done interrupt callbacks to update the VMix layer with the latest frame buffer writer read-pointer address.</para><para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>fbwr_id</parametername>
</parameternamelist>
<parameterdescription>
<para>- Frame buffer writer instance ID (0-3) </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>readAddr</parametername>
</parameternamelist>
<parameterdescription>
<para>- Physical address of the latest completed frame </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>chromaAddr</parametername>
</parameternamelist>
<parameterdescription>
<para>- Physical address of chroma plane (0 for packed formats) Clean up all VMix layers and reset mapping tables</para></parameterdescription>
</parameteritem>
</parameterlist>
Disables all mapped VMix layers, resets layer tracking structures, and clears instance-to-layer mapping tables. </para>        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
