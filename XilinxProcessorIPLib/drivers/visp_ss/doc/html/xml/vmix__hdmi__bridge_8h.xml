        <type>int</type>
        <definition>int VmixHdmiBridge_Init</definition>
        <argsstring>(void)</argsstring>
        <name>VmixHdmiBridge_Init</name>
        <param>
          <type>void</type>
        </param>
        <briefdescription>
<para>Initialize the VMix + HDMI TX bridge. </para>        </briefdescription>
        <detaileddescription>
<para>This function performs the complete initialization:<orderedlist>
<listitem><para>Initializes the VMix IP (XV_Mix_l2)</para></listitem><listitem><para>Initializes the HDMI TX 2.1 SS (XV_HdmiTxSs1) + HDMI PHY</para></listitem><listitem><para>Configures VMix master stream for the target display resolution</para></listitem><listitem><para>Starts the VMix core</para></listitem><listitem><para>Configures and starts HDMI TX output</para></listitem></orderedlist>
</para><para><simplesect kind="return"><para>0 on success, negative on failure </para></simplesect>
</para>        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="/proj/xhdsswstaff1/bhawanas/patch_integration/auto_jobs/esw_github_doxy/git/2026.1/embeddedsw/XilinxProcessorIPLib/drivers/visp_ss/examples/vmix_hdmi_bridge.h" line="121" column="1"/>
      </memberdef>
      <memberdef kind="function" id="vmix__hdmi__bridge_8h_1aae25d585b73d304c594c91555fac5dc0" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>int</type>
        <definition>int VmixHdmiBridge_ConfigHdmiTx</definition>
        <argsstring>(XVidC_VideoMode VideoMode)</argsstring>
        <name>VmixHdmiBridge_ConfigHdmiTx</name>
        <param>
          <type>XVidC_VideoMode</type>
          <declname>VideoMode</declname>
        </param>
        <briefdescription>
<para>Configure the HDMI TX subsystem and start output. </para>        </briefdescription>
        <detaileddescription>
<para>Sets up HDMI TX 2.1 SS with the specified video mode and starts the transmitter. Uses the latest XV_HdmiTxSs1 / XV_Tx APIs.</para><para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>VideoMode</parametername>
</parameternamelist>
<parameterdescription>
<para>- Target video mode (e.g., XVIDC_VM_3840x2160_30_P) </para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>XST_SUCCESS on success </para></simplesect>
</para>        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="/proj/xhdsswstaff1/bhawanas/patch_integration/auto_jobs/esw_github_doxy/git/2026.1/embeddedsw/XilinxProcessorIPLib/drivers/visp_ss/examples/vmix_hdmi_bridge.h" line="132" column="1"/>
