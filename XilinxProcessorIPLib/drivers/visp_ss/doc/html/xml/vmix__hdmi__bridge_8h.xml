        <type>int</type>
        <definition>int VmixHdmiBridge_MapLayer</definition>
        <argsstring>(CamDevicePipeOutFmt_t outFormat, u8 InstanceID, u8 hpId, CamDeviceBufChainId_t bufIo, int dataBits, int outputType)</argsstring>
        <name>VmixHdmiBridge_MapLayer</name>
        <param>
          <type><ref refid="group____cam__device__general_1ga0b046c59fcd3d0271b91cf58ab0c643d" kindref="member">CamDevicePipeOutFmt_t</ref></type>
          <declname>outFormat</declname>
        </param>
        <param>
          <type>u8</type>
          <declname>InstanceID</declname>
        </param>
        <param>
          <type>u8</type>
          <declname>hpId</declname>
        </param>
        <param>
          <type><ref refid="group____buf__mgmt__ctrl_1ga477942d22afe7298d497ae48e8bb498b" kindref="member">CamDeviceBufChainId_t</ref></type>
          <declname>bufIo</declname>
        </param>
        <param>
          <type>int</type>
          <declname>dataBits</declname>
        </param>
        <param>
          <type>int</type>
          <declname>outputType</declname>
        </param>
        <briefdescription>
<para>Map a VMix layer to a specific ISP instance + output path. </para>        </briefdescription>
        <detaileddescription>
<para>Finds a free VMix layer matching the required color format and assigns it to the given ISP instance/path combination.</para><para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>outFormat</parametername>
</parameternamelist>
<parameterdescription>
<para>- ISP output format (resolution, pixel format, bit depth) </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>InstanceID</parametername>
</parameternamelist>
<parameterdescription>
<para>- ISP instance ID (0-5) </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>hpId</parametername>
</parameternamelist>
<parameterdescription>
<para>- Hardware pipeline ID </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>bufIo</parametername>
</parameternamelist>
<parameterdescription>
<para>- Buffer chain ID (MP/SP1) </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>dataBits</parametername>
</parameternamelist>
<parameterdescription>
<para>- Output data bit depth (8 or 10) </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>outputType</parametername>
</parameternamelist>
<parameterdescription>
<para>- 0=MO (memory output), 1=LO (live output via FBWR) </para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>1 on success, 0 if layer already mapped, -1 on failure </para></simplesect>
</para>        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
