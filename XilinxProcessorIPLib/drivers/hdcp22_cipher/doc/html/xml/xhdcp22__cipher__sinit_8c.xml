<parameternamelist>
<parametername>DeviceId</parametername>
</parameternamelist>
<parameterdescription>
<para>is the unique core ID of the XHDCP22 Cipher core for the lookup operation.</para></parameterdescription>
</parameteritem>
</parameterlist>
