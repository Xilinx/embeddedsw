      <memberdef kind="function" id="group__bram_1ga9ce680e885511fdd26b6818b71b145c4" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void</type>
        <definition>void XBram_InterruptDisable</definition>
        <argsstring>(XBram *InstancePtr, u32 Mask)</argsstring>
        <name>XBram_InterruptDisable</name>
        <param>
          <type><ref refid="struct_x_bram" kindref="compound">XBram</ref> *</type>
          <declname>InstancePtr</declname>
        </param>
        <param>
          <type>u32</type>
          <declname>Mask</declname>
        </param>
        <briefdescription>
<para>Disable interrupts. </para>        </briefdescription>
        <detaileddescription>
<para>This function allows each specific interrupt to be disabled. This function will assert if the hardware device has not been built with interrupt capabilities.</para><para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>InstancePtr</parametername>
</parameternamelist>
<parameterdescription>
<para>is the BRAM instance to operate on. </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>Mask</parametername>
</parameternamelist>
<parameterdescription>
<para>is the mask to disable. Bits set to 1 are disabled. This mask is formed by OR&apos;ing bits from XBRAM_IR* bits which are contained in <ref refid="xbram__hw_8h" kindref="compound">xbram_hw.h</ref>.</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>None.</para></simplesect>
<simplesect kind="note"><para>None. </para></simplesect>
</para>        </detaileddescription>
