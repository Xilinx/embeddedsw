      <memberdef kind="function" id="group__xpmonpsv__v2__0_1ga23a2012c0656c0d0c0c05f62ee3b8ee4" prot="public" static="yes" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>u32</type>
        <definition>static u32 XPmonPsv_SelfTest</definition>
        <argsstring>(XPmonPsv *InstancePtr)</argsstring>
        <name>XPmonPsv_SelfTest</name>
        <param>
          <type><ref refid="struct_x_pmon_psv" kindref="compound">XPmonPsv</ref> *</type>
          <declname>InstancePtr</declname>
        </param>
        <briefdescription>
<para>Run a self-test on the driver/device. </para>        </briefdescription>
        <detaileddescription>
<para>The test<itemizedlist>
<listitem><para>Resets the device,</para></listitem><listitem><para>Writes a value into the Range Registers of Incrementer 0 and reads it back for comparison.</para></listitem><listitem><para>Resets the device again.</para></listitem></itemizedlist>
</para><para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>InstancePtr</parametername>
</parameternamelist>
<parameterdescription>
<para>is a pointer to the <ref refid="struct_x_pmon_psv" kindref="compound">XPmonPsv</ref> instance.</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para><itemizedlist>
<listitem><para>XST_SUCCESS if the value read from the Range Register of Incrementer 0 is the same as the value written.</para></listitem><listitem><para>XST_FAILURE Otherwise</para></listitem></itemizedlist>
</para></simplesect>
<simplesect kind="note"><para>This is a destructive test in that resets of the device are performed. Refer to the device specification for the device status after the reset operation. </para></simplesect>
</para>        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="/proj/xhdsswstaff1/bhawanas/patch_integration/auto_jobs/esw_github_doxy/git/2026.1/embeddedsw/XilinxProcessorIPLib/drivers/pmonpsv/examples/xpmonpsv_selftest_example.c" line="83" column="1" bodyfile="/proj/xhdsswstaff1/bhawanas/patch_integration/auto_jobs/esw_github_doxy/git/2026.1/embeddedsw/XilinxProcessorIPLib/drivers/pmonpsv/examples/xpmonpsv_selftest_example.c" bodystart="83" bodyend="122"/>
