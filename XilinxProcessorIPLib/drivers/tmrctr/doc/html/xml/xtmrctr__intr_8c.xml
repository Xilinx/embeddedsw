        <briefdescription>
<para>Sets the timer callback function, which the driver calls when the specified timer times out. </para>        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>InstancePtr</parametername>
</parameternamelist>
<parameterdescription>
<para>is a pointer to the <ref refid="struct_x_tmr_ctr" kindref="compound">XTmrCtr</ref> instance . </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>CallBackRef</parametername>
</parameternamelist>
<parameterdescription>
<para>is the upper layer callback reference passed back when the callback function is invoked. </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>FuncPtr</parametername>
</parameternamelist>
<parameterdescription>
<para>is the pointer to the callback function.</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>None.</para></simplesect>
<simplesect kind="note"><para></para></simplesect>
