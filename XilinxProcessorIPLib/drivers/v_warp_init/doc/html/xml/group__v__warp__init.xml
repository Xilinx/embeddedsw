        <type>void</type>
        <definition>void XVWarpInit_SetCallback</definition>
        <argsstring>(XV_warp_init *InstancePtr, void *CallbackFunc, void *CallbackRef)</argsstring>
        <name>XVWarpInit_SetCallback</name>
        <param>
          <type><ref refid="struct_x_v__warp__init" kindref="compound">XV_warp_init</ref> *</type>
          <declname>InstancePtr</declname>
        </param>
