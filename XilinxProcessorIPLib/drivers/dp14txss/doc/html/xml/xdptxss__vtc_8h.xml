      <memberdef kind="define" id="xdptxss__vtc_8h_1a57fc13eb777500b3e22d3ff457cfd0d7" prot="public" static="no">
        <name>DIV_ROUND_CLOSEST</name>
        <param><defname>n</defname></param>
        <param><defname>d</defname></param>
        <initializer>(((n) + ((d) / 2U)) / (d))</initializer>
        <briefdescription>
<para>Divides n by d and rounds to the nearest integer. </para>        </briefdescription>
        <detaileddescription>
<para>This macro performs integer division with rounding to the nearest integer. It adds half the divisor to the numerator before dividing to achieve round-to-nearest behavior.</para><para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>n</parametername>
</parameternamelist>
<parameterdescription>
<para>Numerator </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>d</parametername>
</parameternamelist>
<parameterdescription>
<para>Divisor </para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>Result of n divided by d, rounded to nearest integer </para></simplesect>
</para>        </detaileddescription>
