<parameternamelist>
<parametername>InstancePtr</parametername>
</parameternamelist>
<parameterdescription>
<para>is a pointer to the <ref refid="struct_x_csi_ss" kindref="compound">XCsiSs</ref> instance.</para></parameterdescription>
</parameteritem>
</parameterlist>
