    <briefdescription>
<para>struct XUsbPsu_event_devt - Device Events Device Events </para>    </briefdescription>
    <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>Is_DevEvt</parametername>
<parametername>:</parametername>
