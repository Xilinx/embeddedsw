        <type>int</type>
        <definition>int XVMix_SetCallback</definition>
        <argsstring>(XV_Mix_l2 *InstancePtr, void *CallbackFunc, void *CallbackRef)</argsstring>
        <name>XVMix_SetCallback</name>
        <param>
          <type><ref refid="struct_x_v___mix__l2" kindref="compound">XV_Mix_l2</ref> *</type>
          <declname>InstancePtr</declname>
        </param>
        <param>
          <type>void *</type>
          <declname>CallbackFunc</declname>
        </param>
        <param>
          <type>void *</type>
          <declname>CallbackRef</declname>
