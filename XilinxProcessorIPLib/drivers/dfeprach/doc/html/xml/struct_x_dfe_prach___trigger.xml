        <type>u32</type>
        <definition>u32 XDfePrach_Trigger::TriggerEnable</definition>
        <argsstring></argsstring>
        <name>TriggerEnable</name>
        <briefdescription>
<para>[0,1], Enable Trigger: </para>        </briefdescription>
        <detaileddescription>
<para><itemizedlist>
<listitem><para>0 = DISABLED: Trigger Pulse and State outputs are disabled.</para></listitem><listitem><para>1 = ENABLED: Trigger Pulse and State outputs are enabled and follow the settings described below. </para></listitem></itemizedlist>
</para>        </detaileddescription>
