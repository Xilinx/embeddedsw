        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>InstancePtr</parametername>
</parameternamelist>
<parameterdescription>
<para>- a pointer to the <ref refid="struct_x_hw_icap" kindref="compound">XHwIcap</ref> instance to be worked on. </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>Top</parametername>
</parameternamelist>
<parameterdescription>
<para>- top (0) or bottom (1) half of device </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>Block</parametername>
</parameternamelist>
<parameterdescription>
<para>- Block Address (XHI_FAR_CLB_BLOCK, XHI_FAR_BRAM_BLOCK, XHI_FAR_BRAM_INT_BLOCK) </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>HClkRow</parametername>
</parameternamelist>
<parameterdescription>
<para>- selects the HClk Row </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>MajorFrame</parametername>
</parameternamelist>
<parameterdescription>
<para>- selects the column </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>MinorFrame</parametername>
</parameternamelist>
<parameterdescription>
<para>- selects frame inside column </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>FrameBuffer</parametername>
</parameternamelist>
<parameterdescription>
<para>is a pointer to the memory where the frame read from the device is stored</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>XST_SUCCESS else XST_FAILURE.</para></simplesect>
<simplesect kind="note"><para>This is a blocking call. </para></simplesect>
</para>        </detaileddescription>
