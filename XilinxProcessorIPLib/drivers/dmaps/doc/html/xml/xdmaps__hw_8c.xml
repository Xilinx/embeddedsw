<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>BaseAddress</parametername>
</parameternamelist>
<parameterdescription>
<para>of the interface</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>N/A</para></simplesect>
<simplesect kind="note"><para>This function will not modify the slcr registers that are relevant for dmaps controller </para></simplesect>
</para>        </detaileddescription>
