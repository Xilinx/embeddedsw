</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>errormask</parametername>
</parameternamelist>
<parameterdescription>
<para>is a bit mask indicating the cause of the error. its value equals &apos;or&apos;ing one or more xdsi2rx_isr_*_mask values defined in xdsi_hw.h.</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>none.</para></simplesect>
<simplesect kind="note"><para>none. </para></simplesect>
</para>        </detaileddescription>
