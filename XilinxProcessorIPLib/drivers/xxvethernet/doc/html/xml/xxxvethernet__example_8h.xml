</preformatted></para><para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>FramePtr</parametername>
</parameternamelist>
<parameterdescription>
<para>is a pointer to the frame to change. </para></parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>PayloadSize</parametername>
</parameternamelist>
<parameterdescription>
<para>is the number of bytes in the payload that will be set.</para></parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>None.</para></simplesect>
<simplesect kind="note"><para>None. </para></simplesect>
</para>        </detaileddescription>
