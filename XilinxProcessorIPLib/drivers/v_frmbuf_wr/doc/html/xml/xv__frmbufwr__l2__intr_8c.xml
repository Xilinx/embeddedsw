        <type>int</type>
        <definition>int XVFrmbufWr_SetCallback</definition>
        <argsstring>(XV_FrmbufWr_l2 *InstancePtr, u32 HandlerType, void *CallbackFunc, void *CallbackRef)</argsstring>
        <name>XVFrmbufWr_SetCallback</name>
        <param>
          <type><ref refid="struct_x_v___frmbuf_wr__l2" kindref="compound">XV_FrmbufWr_l2</ref> *</type>
          <declname>InstancePtr</declname>
        </param>
